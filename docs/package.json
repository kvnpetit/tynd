{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "bun run scripts/build-llms-txt.ts",
    "build": "next build",
    "postbuild": "pagefind --site out --output-path out/_pagefind",
    "llms": "bun run scripts/build-llms-txt.ts",
    "serve": "bunx http-server out -p 8000 -c-1",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "new-version": "bun run scripts/new-version.ts",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.83.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
