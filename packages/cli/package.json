{
  "name": "@tynd/cli",
  "version": "0.2.0",
  "description": "Tynd framework CLI — scaffold, dev, build native TypeScript desktop apps",
  "license": "Apache-2.0",
  "author": "Kevin Petit <74395438+kvnpetit@users.noreply.github.com> (https://github.com/kvnpetit)",
  "homepage": "https://github.com/kvnpetit/tynd#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kvnpetit/tynd.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/kvnpetit/tynd/issues"
  },
  "keywords": [
    "tynd",
    "cli",
    "desktop",
    "webview",
    "bun",
    "typescript",
    "tauri-alternative",
    "electron-alternative"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "private": false,
  "type": "module",
  "sideEffects": false,
  "files": [
    "bin",
    "src/lib/config.ts"
  ],
  "bin": {
    "tynd": "./bin/index.js"
  },
  "exports": {
    ".": "./src/lib/config.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir bin --target bun --format esm",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "adm-zip": "^0.5.17",
    "cac": "^7.0.0",
    "resedit": "^3.0.2",
    "tar-stream": "^3.1.8",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bun": "latest",
    "@types/tar-stream": "^3.1.4"
  }
}
