{
  "name": "@vorn/cli",
  "version": "0.0.0",
  "description": "Vorn framework CLI — create, dev, build",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kvnpetit/vorn"
  },
  "files": [
    "bin",
    "src/lib/config.ts"
  ],
  "bin": {
    "vorn": "./bin/index.js"
  },
  "exports": {
    ".": "./src/lib/config.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir bin --target bun --format esm",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "cac": "^7.0.0",
    "resedit": "^3.0.2",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
