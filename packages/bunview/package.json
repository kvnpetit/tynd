{
  "name": "bunview",
  "version": "0.1.0",
  "type": "module",
  "description": "Native desktop apps with Bun + TypeScript + native webview",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/OWNER/bunview"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./client/index.ts",
    "./shell": "./src/shell.ts",
    "./autolaunch": "./src/autolaunch.ts",
    "./updater": "./src/updater.ts",
    "./http": "./src/http.ts",
    "./binary": "./src/binary.ts",
    "./channel": "./src/channel.ts"
  },
  "bin": {
    "bunview": "./cli/index.ts"
  },
  "scripts": {
    "postinstall": "bun scripts/setup.ts",
    "build:host": "bun scripts/build-host.ts"
  },
  "keywords": [
    "desktop",
    "webview",
    "bun",
    "native"
  ],
  "license": "MIT",
  "dependencies": {
    "picocolors": "^1.1.1",
    "cac": "^6.7.14",
    "@clack/prompts": "^0.11.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.12",
    "png2icons": "^2.0.1",
    "resedit": "^3.0.2"
  }
}
