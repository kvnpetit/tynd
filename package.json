{
  "name": "tynd",
  "version": "0.0.0",
  "description": "Native desktop apps in TypeScript — workspace root",
  "license": "Apache-2.0",
  "author": "Kevin Petit <74395438+kvnpetit@users.noreply.github.com> (https://github.com/kvnpetit)",
  "homepage": "https://github.com/kvnpetit/tynd#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kvnpetit/tynd.git"
  },
  "bugs": {
    "url": "https://github.com/kvnpetit/tynd/issues"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "private": true,
  "workspaces": [
    "packages/*",
    "playground/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '@tynd/*' typecheck",
    "lint": "biome lint",
    "format": "biome format --write",
    "format:check": "biome format",
    "check": "biome check --write",
    "check:ts": "biome ci && bun run typecheck",
    "fmt:rust": "cargo fmt --all",
    "fmt:rust:check": "cargo fmt --all -- --check",
    "lint:rust": "cargo clippy --workspace --all-targets -- -D warnings",
    "check:rust": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings && cargo check --workspace --all-targets",
    "check:all": "bun run check:ts && bun run check:rust && bun run test",
    "fix:all": "biome check --write && cargo fmt --all",
    "test": "bun test && cargo test --workspace --quiet",
    "test:ts": "bun test",
    "test:rust": "cargo test --workspace"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tynd/cli": "workspace:*",
    "@tynd/core": "workspace:*",
    "@types/bun": "latest",
    "typescript": "~6.0.2"
  }
}
